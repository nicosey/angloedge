---
import Base from './Base.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author?: string;
}

const { title, description, pubDate } = Astro.props;
const formattedDate = new Date(pubDate).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
---

<Base title={title} description={description} url={Astro.url.href}>
  <article class="max-w-prose mx-auto px-6 py-12">
    <header class="mb-8">
      <a href="/" class="text-sm text-brass hover:text-navy transition-colors mb-4 inline-block">← Back to briefings</a>
      <h1 class="font-serif text-4xl font-bold text-navy dark:text-brass mb-4 leading-tight">{title}</h1>
      <time class="text-gray-600 dark:text-gray-400 text-sm">{formattedDate}</time>
    </header>
    
    <div class="prose prose-lg max-w-prose dark:prose-dark font-serif leading-tight space-y-6">
      <slot />
    </div>
  </article>
</Base>

<style>
  :global(h2) {
    @apply font-serif text-2xl font-bold text-navy mt-8 mb-4;
  }
  
  :global(h3) {
    @apply font-serif text-xl font-bold text-navy mt-6 mb-3;
  }
  
  :global(p) {
    @apply leading-tight text-gray-900;
  }
  
  :global(ul), :global(ol) {
    @apply ml-6 space-y-2;
  }
  
  :global(li) {
    @apply leading-tight;
  }
  
  :global(a) {
    @apply text-navy hover:underline transition-all;
  }
  
  :global(blockquote) {
    @apply pl-6 border-l-4 border-brass text-gray-700 italic my-6;
  }
  
  :global(code) {
    @apply bg-gray-100 px-2 py-1 rounded text-sm font-mono;
  }
  
  :global(pre) {
    @apply bg-gray-100 p-4 rounded-lg overflow-x-auto;
  }
</style>
