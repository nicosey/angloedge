---
import Base from '../layouts/Base.astro';
---

<Base title="Contact – AngloEdge" description="Get in touch with AngloEdge for research, speaking, advisory, or general inquiries.">
  <div class="max-w-prose mx-auto px-6 py-12">
    <header class="mb-12">
      <h1 class="font-serif text-5xl font-bold text-navy mb-4">Get in Touch</h1>
      <p class="text-gray-600 text-lg">
        We're always interested in discussing potential projects, speaking opportunities, and partnerships. Fill out the form below.
      </p>
    </header>

    <form 
      name="contact" 
      method="POST" 
      netlify 
      class="space-y-6"
    >
      <input type="hidden" name="form-name" value="contact" />
      
      <div>
        <label for="name" class="block font-medium text-navy mb-2">Name</label>
        <input 
          type="text" 
          id="name" 
          name="name" 
          required 
          class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-navy"
        />
      </div>

      <div>
        <label for="company" class="block font-medium text-navy mb-2">Company/Organisation</label>
        <input 
          type="text" 
          id="company" 
          name="company" 
          class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-navy"
        />
      </div>

      <div>
        <label for="email" class="block font-medium text-navy mb-2">Email</label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          required 
          class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-navy"
        />
      </div>

      <div>
        <label for="enquiry-type" class="block font-medium text-navy mb-2">Enquiry Type</label>
        <select 
          id="enquiry-type" 
          name="enquiry-type" 
          required 
          class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-navy"
        >
          <option value="">Select an option</option>
          <option value="research">Custom Research Report</option>
          <option value="speaking">Speaking Engagement</option>
          <option value="advisory">Advisory/Retainer</option>
          <option value="general">General Inquiry</option>
          <option value="press">Media/Press</option>
        </select>
      </div>

      <div>
        <label for="message" class="block font-medium text-navy mb-2">Message</label>
        <textarea 
          id="message" 
          name="message" 
          rows="6" 
          required 
          class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-navy"
        ></textarea>
      </div>

      <div>
        <button 
          type="submit" 
          class="px-6 py-3 bg-navy text-white font-medium rounded hover:bg-blue-900 transition-colors"
        >
          Send Message
        </button>
      </div>
    </form>

    <div class="mt-16 pt-12 border-t border-gray-200">
      <h2 class="font-serif text-2xl font-bold text-navy mb-4">Or Reach Out Directly</h2>
      <p>
        For urgent inquiries or to connect directly, find us on <a href="https://x.com/angloedgee" class="text-navy hover:underline">X (@angloedgee)</a>.
      </p>
    </div>
  </div>

  <script>
    // Pre-fill enquiry type if passed as URL parameter
    const params = new URLSearchParams(window.location.search);
    const service = params.get('service');
    
    if (service) {
      const enquiryTypeSelect = document.getElementById('enquiry-type');
      enquiryTypeSelect.value = service;
    }
  </script>
</Base>
