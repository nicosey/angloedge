---
---

<div class="uk-markets-compact bg-navy rounded-lg overflow-hidden border border-white/10 mb-8">
  <div class="flex items-center justify-between px-4 py-2 border-b border-white/10">
    <span class="text-[10px] font-sans font-semibold text-brass uppercase tracking-widest">
      UK Markets — Live Prices
    </span>
    <time id="compact-timestamp" class="text-[10px] font-sans text-white/40 tabular-nums" datetime=""></time>
  </div>
  <!-- TradingView Ticker Tape: a slim horizontal scrolling strip -->
  <div>
    <div class="tradingview-widget-container">
      <div class="tradingview-widget-container__widget"></div>
      <script is:inline type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-ticker-tape.js" async>
      {"symbols":[{"proName":"OANDA:UK100GBP","title":"FTSE 100"},{"proName":"FX:GBPUSD","title":"GBP/USD"},{"proName":"FX:EURGBP","title":"EUR/GBP"},{"proName":"TVC:UKOIL","title":"Brent"},{"proName":"TVC:GOLD","title":"Gold"},{"proName":"BITSTAMP:BTCUSD","title":"Bitcoin"}],"showSymbolLogo":false,"colorTheme":"dark","isTransparent":true,"displayMode":"compact","locale":"en"}
      </script>
    </div>
  </div>
</div>

<script>
  function setCompactTimestamp() {
    const el = document.getElementById('compact-timestamp');
    if (!el) return;
    const now = new Date();
    el.textContent = now.toLocaleTimeString('en-GB', {
      hour: '2-digit',
      minute: '2-digit',
      timeZone: 'Europe/London',
      timeZoneName: 'short',
    });
    el.setAttribute('datetime', now.toISOString());
  }

  setCompactTimestamp();
  document.addEventListener('astro:page-load', setCompactTimestamp);
</script>
