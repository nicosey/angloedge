<script>
  const YF = 'https://query1.finance.yahoo.com/v8/finance/chart/';

  const INSTRUMENTS = [
    { id: 'ftse100', symbol: '%5EFTSE',   type: 'index',     decimals: 2, prefix: ''  },
    { id: 'ftse250', symbol: '%5EFTMC',   type: 'index',     decimals: 2, prefix: ''  },
    { id: 'gb10y',   symbol: 'GB10Y%3DX', type: 'yield',     decimals: 2, prefix: ''  },
    { id: 'gb30y',   symbol: 'GB30Y%3DX', type: 'yield',     decimals: 2, prefix: ''  },
    { id: 'gbpusd',  symbol: 'GBPUSD%3DX',type: 'fx',        decimals: 4, prefix: ''  },
    { id: 'brent',   symbol: 'BZ%3DF',    type: 'commodity', decimals: 2, prefix: '$' },
  ];

  async function fetchQuote(symbol) {
    try {
      const r = await fetch(`${YF}${symbol}?interval=1m&range=1d`);
      if (!r.ok) return null;
      const d = await r.json();
      const m = d?.chart?.result?.[0]?.meta;
      if (!m) return null;
      return {
        price: m.regularMarketPrice,
        change: m.regularMarketChange,
        pct: m.regularMarketChangePercent,
      };
    } catch { return null; }
  }

  function fmtPrice(price, type, decimals, prefix) {
    if (price == null) return '—';
    if (type === 'yield') return price.toFixed(2) + '%';
    if (type === 'index') return price.toLocaleString('en-GB', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    return prefix + price.toFixed(decimals);
  }

  function fmtChange(change, pct, type) {
    if (change == null) return '—';
    const sign = change >= 0 ? '+' : '';
    if (type === 'yield') return `${sign}${Math.round(change * 100)} bps`;
    return `${sign}${pct.toFixed(2)}%`;
  }

  async function refresh() {
    const results = await Promise.all(INSTRUMENTS.map(i => fetchQuote(i.symbol)));

    INSTRUMENTS.forEach((inst, idx) => {
      const card = document.getElementById(`card-${inst.id}`);
      if (!card) return;
      const priceEl = card.querySelector('.card-price');
      const changeEl = card.querySelector('.card-change');
      const q = results[idx];
      if (q) {
        priceEl.textContent = fmtPrice(q.price, inst.type, inst.decimals, inst.prefix);
        changeEl.textContent = fmtChange(q.change, q.pct, inst.type);
        changeEl.className = `card-change text-[11px] font-sans font-medium mt-1 ${q.change >= 0 ? 'text-emerald-400' : 'text-red-400'}`;
      }
    });

    const ts = document.getElementById('markets-ts');
    if (ts) {
      const now = new Date();
      ts.textContent = 'Last updated: ' + now.toLocaleDateString('en-GB', {
        day: 'numeric', month: 'short', year: 'numeric',
      }) + ' ' + now.toLocaleTimeString('en-GB', {
        hour: '2-digit', minute: '2-digit', timeZone: 'Europe/London', timeZoneName: 'short',
      });
      ts.setAttribute('datetime', now.toISOString());
    }
  }

  refresh();
  document.getElementById('markets-refresh-all')?.addEventListener('click', refresh);
  document.addEventListener('astro:page-load', refresh);
</script>
