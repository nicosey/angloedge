    </div>
    <button id="markets-refresh-all" class="text-white/30 hover:text-brass transition-colors text-base leading-none ml-3" aria-label="Refresh">
      ↻
    </button>
  </div>

  <div class="grid grid-cols-2 gap-px bg-white/5">

    <div class="bg-navy h-[148px] overflow-hidden">
